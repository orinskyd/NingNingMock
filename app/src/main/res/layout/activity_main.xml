<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="宁宁模拟"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatusBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="就绪"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 搜索栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/search_bg"
            android:hint="搜索地点..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="搜索"
            android:src="@android:drawable/ic_menu_search"
            android:tint="#1565C0" />

        <ProgressBar
            android:id="@+id/progressSearch"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="4dp"
            android:visibility="gone"
            style="?android:attr/progressBarStyleSmall" />
    </LinearLayout>

    <!-- 地图区域 + 浮动按钮 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- osmdroid 地图 -->
        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 浮动按钮容器 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:orientation="vertical"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp">

            <!-- 图层切换 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabLayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:contentDescription="图层"
                android:src="@android:drawable/ic_menu_mapmode"
                app:backgroundTint="#FFFFFF"
                app:tint="#1565C0"
                app:fabSize="mini" />

            <!-- 我的位置 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabMyLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="我的位置"
                android:src="@android:drawable/ic_menu_mylocation"
                app:backgroundTint="#FFFFFF"
                app:tint="#1565C0"
                app:fabSize="mini" />

            <!-- 历史记录 / 收藏 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:contentDescription="历史与收藏"
                android:src="@android:drawable/ic_menu_recent_history"
                app:backgroundTint="#FFFFFF"
                app:tint="#1565C0"
                app:fabSize="mini" />
        </LinearLayout>
    </FrameLayout>

    <!-- 已选位置卡片 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSelected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:visibility="gone"
        android:elevation="4dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 位置名 + 收藏按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvLocationName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="已选位置"
                    android:textColor="#202124"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <ImageButton
                    android:id="@+id/btnFavorite"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="收藏"
                    android:src="@android:drawable/btn_star_big_off" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCoords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="#5F6368"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 底部操作区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <!-- 自动后台开关 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchAutoBackground"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="启动后自动进入后台"
                android:textSize="13sp"
                android:textColor="#5F6368"
                android:checked="true" />

            <TextView
                android:id="@+id/tvWifiStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#5F6368"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 状态信息 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#5F6368"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <!-- 主按钮 -->
        <Button
            android:id="@+id/btnStartMock"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:backgroundTint="#1976D2"
            android:enabled="false"
            android:text="开始模拟"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="26dp" />
    </LinearLayout>
</LinearLayout>
